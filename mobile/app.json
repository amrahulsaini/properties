{
  "expo": {
    "name": "Samarth Properties",
    "slug": "samarth-properties",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffaf5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.samarth.properties"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fffaf5"
      },
      "package": "com.samarth.properties",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Samarth Properties to use your location for site records."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Samarth Properties to access your photos for document uploads."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "samarth"
  }
}
